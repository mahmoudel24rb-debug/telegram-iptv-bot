# =============================================================
# BingeBear TV — Variables d'environnement
# Copier ce fichier dans python-bot/.env et remplir les valeurs
# =============================================================

# --- OBLIGATOIRES ---

# Telegram API (depuis https://my.telegram.org)
API_ID=12345678
API_HASH=votre_api_hash_ici

# Bot Token (depuis @BotFather)
BOT_TOKEN=123456789:ABCdefGhIjKlMnOpQrStUvWxYz

# ID du groupe/canal cible pour le streaming
CHAT_ID=bingebeartv_live

# Session string Pyrogram (generer avec generate_session.py)
SESSION_STRING=votre_session_string_ici

# Serveur IPTV Xtream Codes
IPTV_SERVER_URL=http://votre-serveur-iptv.com
IPTV_USERNAME=votre_username
IPTV_PASSWORD=votre_password

# --- OPTIONNELLES ---

# IDs Telegram des admins (separes par des virgules)
ADMIN_IDS=123456789

# Usernames autorises pour le streaming (separes par des virgules)
ALLOWED_USERNAMES=DefiMack

# News Forwarder
NEWS_SOURCE_CHANNEL=-1001763758614
NEWS_DEST_CHANNEL=@bingebeartv_live

# Logging
LOG_DIR=/var/log/bingebear

# Health check
HEALTH_PORT=8080

# Etat du stream (persistance pour auto-restart)
STREAM_STATE_FILE=/home/bingebear/TelegramIPTVBot/python-bot/stream_state.json
STREAM_STATE_MAX_AGE=1800

# Cache news (anti-doublons)
NEWS_CACHE_FILE=/home/bingebear/TelegramIPTVBot/python-bot/news_cache.json
