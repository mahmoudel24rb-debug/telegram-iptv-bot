# Configuration Telegram
API_ID=your_api_id
API_HASH=your_api_hash
BOT_TOKEN=your_bot_token

# Groupe/Canal pour le streaming (username sans @)
CHAT_ID=your_group_username

# Session string (généré avec generate_session.py)
SESSION_STRING=your_session_string

# Configuration IPTV
IPTV_SERVER_URL=http://your-iptv-server.com
IPTV_USERNAME=your_username
IPTV_PASSWORD=your_password

# Admin IDs (optionnel, séparés par des virgules)
ADMIN_IDS=123456789

# Fichier de persistance des rappels récurrents
REMINDERS_FILE=./reminders.json
