# === Telegram ===
API_ID=
API_HASH=
BOT_TOKEN=
CHAT_ID=
SESSION_STRING=

# === IPTV ===
IPTV_SERVER_URL=
IPTV_USERNAME=
IPTV_PASSWORD=

# === Claude API ===
ANTHROPIC_API_KEY=

# === Admin ===
ADMIN_IDS=
ALLOWED_USERNAMES=DefiMack

# === News Forwarder ===
# Liste des canaux sources separes par virgules (1 ou plusieurs)
NEWS_SOURCE_CHANNELS=-1001763758614,-1009876543210
# Ancien format (toujours supporte en fallback) :
# NEWS_SOURCE_CHANNEL=-1001763758614
NEWS_DEST_CHANNEL=@bingebeartv_live
NEWS_POLL_INTERVAL=7200
CLAUDE_MAX_CALLS_PER_CYCLE=50

# === Promotions ===
TZ_OFFSET_HOURS=0

# === Articles WordPress ===
WP_API_BASE=https://bingebear.tv/wp-json/wp/v2
WP_FEATURED_TAG_ID=                       # ID du tag "Featured Telegram" (vide = pas de post du soir)
WP_EXCLUDE_TAG_ID=                        # ID du tag "no-telegram" (optionnel)
ARTICLE_MORNING_HOUR=9                    # heure locale du post matin (0-23)
ARTICLE_EVENING_HOUR=18                   # heure locale du post soir
ARTICLE_WORKER_ENABLED=true               # false pour desactiver

# === Health Check ===
HEALTH_PORT=8080

# === Logging ===
LOG_DIR=./logs
